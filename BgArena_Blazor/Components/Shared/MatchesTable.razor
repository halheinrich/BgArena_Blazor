@if (Matches.Count == 0)
{
    <p class="muted">No matches yet.</p>
}
else
{
    <table class="data-table matches-table">
        <thead>
            <tr>
                <th>Match</th>
                <th>Engines</th>
                <th>Length</th>
                <th>Status</th>
                <th>Winner</th>
                <th>Score</th>
                <th>When (UTC)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var match in Matches)
            {
                <tr>
                    <td><a href="@($"matches/{match.MatchId}")">@match.MatchId</a></td>
                    <td>@match.EngineOne vs @match.EngineTwo</td>
                    <td>
                        @ArenaDisplay.LengthText(match.MatchLength, match.MaxGames)
                        <ClockIndicator TimeControl="match.TimeControl" />
                    </td>
                    <td>
                        <span class="@ArenaDisplay.StatusCss(match.Status)">@match.Status</span>
                        @* The structured forfeit cause rides beside the status pill;
                           the prose detail stays on the detail card. *@
                        @if (match.ForfeitCause is { } cause)
                        {
                            <span class="@ArenaDisplay.ForfeitCauseCss(cause)">@ArenaDisplay.ForfeitCauseText(cause)</span>
                        }
                        @if (match.Status == MatchStatus.Running)
                        {
                            <a class="watch-live" href="@($"matches/{match.MatchId}/live")">watch</a>
                        }
                    </td>
                    <td>@(match.Winner ?? "—")</td>
                    <td>@ArenaDisplay.ScoreText(match)</td>
                    <td class="when-cell">@ArenaDisplay.WhenText(match.StartedAtUtc, match.EndedAtUtc)</td>
                </tr>
            }
        </tbody>
    </table>
}
