@page "/matches/{MatchId}"
@inherits PollingComponentBase

<PageTitle>Match @MatchId — BgArena</PageTitle>

@if (IsUnreachable)
{
    <ConnectionBanner />
}

@if (NotFound)
{
    <h1>Match</h1>
    <div class="banner banner-error" role="alert">No match with id '@MatchId'.</div>
    <p><a href="matches">Back to matches</a></p>
}
else if (Match is null)
{
    <h1>Match</h1>
    <p class="muted">Loading…</p>
}
else
{
    <h1>@Match.EngineOne vs @Match.EngineTwo</h1>

    <dl class="detail-card">
        <dt>Match id</dt>
        <dd>@Match.MatchId</dd>
        <dt>Length</dt>
        <dd>@ArenaDisplay.LengthText(Match.MatchLength, Match.MaxGames)</dd>
        <dt>Time control</dt>
        <dd id="time-control">@ArenaDisplay.TimeControlText(Match.TimeControl)</dd>
        <dt>Status</dt>
        <dd><span class="@ArenaDisplay.StatusCss(Match.Status)">@Match.Status</span></dd>
        <dt>Winner</dt>
        <dd>@(Match.Winner ?? "—")</dd>
        <dt>Score</dt>
        <dd>@ArenaDisplay.ScoreText(Match)</dd>
        <dt>Seed</dt>
        <dd>@Match.Seed</dd>
        <dt>Started (UTC)</dt>
        <dd id="started-at">@ArenaDisplay.TimestampText(Match.StartedAtUtc)</dd>
        <dt>Ended (UTC)</dt>
        <dd id="ended-at">@ArenaDisplay.EndedText(Match.Status != MatchStatus.Running, Match.StartedAtUtc, Match.EndedAtUtc)</dd>
        @if (Match.MaxGames is { } maxGames && Match.MatchLength != 0)
        {
            <dt>Games cap</dt>
            <dd>@maxGames</dd>
        }
        @if (Match.ForfeitedBy is { } forfeitedBy)
        {
            <dt>Forfeited by</dt>
            <dd>
                @forfeitedBy
                @* The structured cause beside the name; Detail below stays the
                   human-readable companion. *@
                @if (Match.ForfeitCause is { } cause)
                {
                    <span class="@ArenaDisplay.ForfeitCauseCss(cause)">@ArenaDisplay.ForfeitCauseText(cause)</span>
                }
            </dd>
        }
        @if (Match.Detail is { } detail)
        {
            <dt>Detail</dt>
            <dd>@detail</dd>
        }
    </dl>

    @if (Match.Status == MatchStatus.Running)
    {
        <a id="watch-live-link" class="button" href="@($"matches/{Match.MatchId}/live")">Watch live</a>
    }
    else
    {
        @* Every terminal match has a replay: the full transcript when Completed,
           the games that finished before the break otherwise (the page signals
           the partiality). *@
        <a id="replay-link" class="button" href="@($"matches/{Match.MatchId}/replay")">View replay</a>
        @* …its arbitration timeline (the audit surface — timestamps, clock
           evidence, the structured outcome)… *@
        <a id="audit-link" class="button" href="@($"matches/{Match.MatchId}/audit")">View audit</a>
        @* …and a downloadable Jellyfish .MAT of the same transcript. The href is
           this host's relay (a same-origin file download — plain anchor, the
           attachment disposition drives the browser), not the internal server. *@
        <a id="download-mat-link" class="button" href="@($"matches/{Match.MatchId}/export.mat")">Download .MAT</a>
    }

    <p><a href="matches">Back to matches</a></p>
}
